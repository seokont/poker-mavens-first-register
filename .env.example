# Poker Mavens API
POKER_API_URL=http://127.0.0.1:8087/api
POKER_API_PASSWORD=your_api_password_here
POKER_SERVER_URL=http://127.0.0.1:8087

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SESSION_SECRET=change-me-in-production

# Avatar sprite sheet (Poker Mavens v5 uses 32px tiles)
POKER_AVATAR_URL=http://127.0.0.1:8087/Image?Name=Avatars
POKER_AVATAR_MAX=64
POKER_AVATAR_SIZE=32

# Public avatar URL exposed to the browser (same as above unless proxied)
NEXT_PUBLIC_AVATAR_URL=http://127.0.0.1:8087/Image?Name=Avatars
NEXT_PUBLIC_AVATAR_MAX=64
NEXT_PUBLIC_AVATAR_SIZE=32
